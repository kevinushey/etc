#!/usr/bin/env bash

## This script installs R using clang, the latest version of gfortran,
## and also OpenBLAS for faster matrix operations. By default the latest
## R-devel is checked out from SVN; pass `--version X.Y.Z` to download
## and build a specific release from CRAN instead. Run with `--help` for
## the full set of options.
##
## NOTE: this script will install Homebrew, a Mac package manager,
## for easy downloading of gfortran, OpenBLAS, and LAPACK.
##
## NOTE: If you get weird linker errors related to `lapack` in grDevices
## on load, it's probably because you updated gcc / gfortran and now
## the lapack / openblas links are broken. You can either fix this
## manually with otool, or be lazy and just reinstall openblas and
## lapack (in that order).
##

[ -e ~/.bashrc ] && . ~/.bashrc

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] [-- configure_args...]

Build and install R from source.

Options:
  --version <X.Y.Z>     Build R release X.Y.Z from a CRAN source tarball.
  --devel               Build the latest R-devel from SVN trunk (default).
  --sanitizers <list>   Comma-separated sanitizers to enable. Supported:
                        asan, ubsan. Example: --sanitizers asan,ubsan.
  --help, -h            Show this help message and exit.

When --sanitizers is passed, a corresponding suffix (e.g. -asan,
-ubsan, -asan-ubsan) is appended to the install prefix and user
library path so sanitized builds don't collide with regular ones.

Unrecognized arguments, or anything after a literal '--', are forwarded
verbatim to ./configure.
EOF
}

R_VERSION=""
USE_DEVEL=""
SANITIZERS=""
CONFIGURE_ARGS=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --devel)
            USE_DEVEL=1
            shift
            ;;
        --version)
            if [ "$#" -lt 2 ]; then
                warn "--version requires an argument"
                exit 1
            fi
            R_VERSION="$2"
            shift 2
            ;;
        --version=*)
            R_VERSION="${1#--version=}"
            shift
            ;;
        --sanitizers)
            if [ "$#" -lt 2 ]; then
                warn "--sanitizers requires an argument"
                exit 1
            fi
            SANITIZERS="$2"
            shift 2
            ;;
        --sanitizers=*)
            SANITIZERS="${1#--sanitizers=}"
            shift
            ;;
        --)
            shift
            CONFIGURE_ARGS+=("$@")
            break
            ;;
        *)
            CONFIGURE_ARGS+=("$1")
            shift
            ;;
    esac
done

if [ -n "${USE_DEVEL}" ] && [ -n "${R_VERSION}" ]; then
    warn "--devel and --version are mutually exclusive"
    exit 1
fi

if [ -n "${R_VERSION}" ] && ! [[ "${R_VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    warn "--version expects X.Y.Z (got '${R_VERSION}')"
    exit 1
fi

## ----- SANITIZER REGISTRY ----- ##
##
## To add a sanitizer NAME, add it (lowercase) to SUPPORTED_SANITIZERS
## and define the matching uppercase NAME_CPP_FLAGS, NAME_LD_LIBS, and
## NAME_RUNTIME_ENV variables below. The accumulator below picks them
## up by name via indirection.
##
SUPPORTED_SANITIZERS=(asan ubsan)

ASAN_CPP_FLAGS="-fsanitize=address -fsanitize-recover=address"
ASAN_LD_LIBS="-lclang_rt.asan_osx_dynamic"
ASAN_RUNTIME_ENV="ASAN_OPTIONS=detect_leaks=0:halt_on_error=0"

UBSAN_CPP_FLAGS="-fsanitize=undefined -fsanitize-recover=undefined -fno-sanitize=alignment,function,float-divide-by-zero"
UBSAN_LD_LIBS="-lclang_rt.ubsan_osx_dynamic"
UBSAN_RUNTIME_ENV="UBSAN_OPTIONS=halt_on_error=0:print_stacktrace=0"

## Parse and validate the requested sanitizer list.
SAN_REQUESTED=()
if [ -n "${SANITIZERS}" ]; then
    IFS=',' read -ra _SAN_RAW <<< "${SANITIZERS}"
    for s in "${_SAN_RAW[@]}"; do
        s="${s,,}"
        s="${s//[[:space:]]/}"
        [ -z "${s}" ] && continue
        case " ${SUPPORTED_SANITIZERS[*]} " in
            *" ${s} "*) SAN_REQUESTED+=("${s}") ;;
            *)
                warn "Unknown sanitizer '${s}' (supported: ${SUPPORTED_SANITIZERS[*]})"
                exit 1
                ;;
        esac
    done
fi

## Accumulate the per-sanitizer pieces in canonical (registry) order
## so the install suffix is deterministic regardless of input order.
SAN_SUFFIX=""
SAN_CPP_FLAGS=""
SAN_LD_LIBS=""
SAN_RUNTIME_ENV=()
for s in "${SUPPORTED_SANITIZERS[@]}"; do
    case " ${SAN_REQUESTED[*]} " in
        *" ${s} "*) ;;
        *) continue ;;
    esac
    upper="${s^^}"
    cpp_var="${upper}_CPP_FLAGS"
    ld_var="${upper}_LD_LIBS"
    env_var="${upper}_RUNTIME_ENV"
    SAN_SUFFIX+="-${s}"
    SAN_CPP_FLAGS+=" ${!cpp_var}"
    SAN_LD_LIBS+=" ${!ld_var}"
    [ -n "${!env_var}" ] && SAN_RUNTIME_ENV+=("${!env_var}")
done

USE_SANITIZERS=""
[ -n "${SAN_SUFFIX}" ] && USE_SANITIZERS=1

## ----- END SANITIZER REGISTRY ----- ##

if [ "$(arch)" = "arm64" ]; then
	HOMEBREW_PREFIX=/opt/homebrew
	PATH="/opt/R/arm64/bin:${PATH}"
else
	HOMEBREW_PREFIX=/usr/local
fi

## ----- CONFIGURATION VARIABLES ----- ##

# Installation-related
: ${SOURCEDIR="${HOME}/r/r-source"}          # checked out R sources will live here
: ${TMP="${HOME}/tmp"}                       # temporary dir used on installation

## Sanitizer-aware compiler defaults. Apple's clang doesn't ship the
## sanitizer runtime libraries, so we use Homebrew's LLVM clang and
## bake the sanitizer flags into CC/CXX so they reach R itself and
## any packages built with R CMD afterwards. Optimization is dropped
## to -O1 because sanitizer builds at -O3 are painfully slow.
if [ -n "${USE_SANITIZERS}" ]; then
    : ${CLANG="${HOMEBREW_PREFIX}/opt/llvm/bin/clang"}
    : ${MACOSX_SDK_PATH="$(xcrun --show-sdk-path 2>/dev/null || echo /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk)"}
    : ${SANFLAGS="-isysroot ${MACOSX_SDK_PATH} -fno-omit-frame-pointer${SAN_CPP_FLAGS}"}
    : ${CC="${CLANG} ${SANFLAGS}"}
    : ${CXX="${CLANG}++ ${SANFLAGS}"}
    : ${OBJC="${CLANG}"}
    : ${CFLAGS="-g -O1 -Wall -pedantic"}
    : ${CXXFLAGS="-g -O1 -Wall -pedantic"}
fi

## Compiler-specific
: ${CC="clang"}
: ${CXX="clang++"}
: ${CFLAGS="-g -O3 -Wall -pedantic"}
: ${CPPFLAGS="-I${HOMEBREW_PREFIX}/include"}
: ${CXXFLAGS="-g -O3 -Wall -pedantic"}
: ${FORTRAN="gfortran"}
: ${FFLAGS="-g -O3"}
: ${OBJC="clang"}
: ${OBJCFLAGS="${CFLAGS}"}
: ${MAKE="make"}
: ${MAKEFLAGS="-j10"}
: ${LDFLAGS="-L${HOMEBREW_PREFIX}/lib"}

## ----- END CONFIGURATION VARIABLES ----- ##

OWD=`pwd`

## check if homebrew is installed
if command -v brew &> /dev/null; then
    info "Homebrew is already installed."
else
    info "Installing homebrew..."
    /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    info "Homebrew successfully installed."
fi

export TMP=${TMP}
mkdir -p "${TMP}"

missing () {
    if ! test -z `brew list --formula | grep ^$1$`; then
        echo 1
    fi
}

install () {
    if test -z `missing $1`; then
        brew install $@
    fi
}

## make sure we have the necessary taps
brew tap homebrew/science 2> /dev/null
brew tap homebrew/dupes   2> /dev/null

## use homebrew to install openblas, lapack, gfortran

install gcc        # gfortran
install openblas   # faster BLAS
install lapack     # latest lapack
install texinfo    # vignettes, help
install coreutils  # greadlink
install jpeg       # image write support
install cairo      # image write support

if [ -n "${USE_SANITIZERS}" ]; then
    install llvm   # provides clang with sanitizer runtime libraries
fi

## MAIN_LD wants the sanitizer runtime path, which we can only ask
## clang for after llvm is installed; otherwise it's a plain clang.
if [ -n "${USE_SANITIZERS}" ]; then
    SAN_RT_PATH="$("${CLANG}" --print-file-name=lib/darwin)"
    : ${MAIN_LD="${CLANG}++ ${SANFLAGS} -L${SAN_RT_PATH}${SAN_LD_LIBS}"}
else
    : ${MAIN_LD="clang"}
fi

## Download R sources
mkdir -p "${SOURCEDIR}" &> /dev/null
cd "${SOURCEDIR}"

if [ -n "${R_VERSION}" ]; then
    R_MAJOR="${R_VERSION%%.*}"
    TARBALL="R-${R_VERSION}.tar.gz"
    TARBALL_URL="https://cran.r-project.org/src/base/R-${R_MAJOR}/${TARBALL}"
    BUILD_DIR="R-${R_VERSION}"

    if [ ! -e "${TARBALL}" ]; then
        info "Downloading ${TARBALL_URL}..."
        curl -fLO "${TARBALL_URL}" || {
            warn "Failed to download ${TARBALL_URL}"
            exit 1
        }
    fi

    ## Re-extract from scratch so patches apply against pristine sources,
    ## mirroring the `svn revert` step used for trunk builds below.
    if [ -d "${BUILD_DIR}" ]; then
        info "Removing existing source tree at ${BUILD_DIR}..."
        rm -rf "${BUILD_DIR}"
    fi
    info "Extracting ${TARBALL}..."
    tar -xzf "${TARBALL}"
    cd "${BUILD_DIR}"

    R_TAG="R-${R_VERSION}"
else
    info "Checking out latest R..."
    svn checkout https://svn.r-project.org/R/trunk/
    cd trunk

    SVN_REVISION=$(svn info | grep "Revision" | awk '{print $2}')
    R_TAG="r${SVN_REVISION}"

    ## Recommended packages aren't bundled with the SVN sources; CRAN
    ## release tarballs already include them.
    info "Syncing recommended R packages..."
    ./tools/rsync-recommended
fi

## Append any sanitizer suffix so sanitized builds get their own
## install prefix and user library directory.
R_TAG="${R_TAG}${SAN_SUFFIX}"
: ${PREFIX="/opt/R/${R_TAG}"}

info "Using prefix: ${PREFIX}"

## Apply any patches found in the patches/ directory next to this script
PATCHES_DIR="${SCRIPT_DIR}/patches"
if [ -d "${PATCHES_DIR}" ]; then
    PATCHES=()
    for PATCH in "${PATCHES_DIR}"/*.patch "${PATCHES_DIR}"/*.diff; do
        [ -e "${PATCH}" ] && PATCHES+=("${PATCH}")
    done
    if [ "${#PATCHES[@]}" -gt 0 ]; then
        if [ -z "${R_VERSION}" ]; then
            info "Reverting any local source modifications before applying patches..."
            svn revert -R . > /dev/null
        fi
        for PATCH in "${PATCHES[@]}"; do
            info "Applying patch: $(basename "${PATCH}")"
            # Detect strip level: git-style patches use a/ b/ prefixes (-p1),
            # SVN-style patches do not (-p0).
            case "$(grep -m1 '^--- ' "${PATCH}" | awk '{print $2}')" in
                a/*) STRIP=1 ;;
                *)   STRIP=0 ;;
            esac
            patch "-p${STRIP}" < "${PATCH}" || {
                warn "Failed to apply patch: $(basename "${PATCH}")"
                exit 1
            }
        done
    fi
fi

## For some reason, there is trouble in locating Homebrew Cairo;
## we have to make sure pkg-config looks in the right place
export PKG_CONFIG_PATH=/opt/X11/lib/pkgconfig

## modify config.site so that it gets the appropriate compilers etc
cat > config.site <<- EOM
CC="${CC}"
CFLAGS="${CFLAGS}"
CPPFLAGS="${CPPFLAGS}"
CXX="${CXX}"
CXXFLAGS="${CXXFLAGS}"
F77="${FORTRAN}"
FFLAGS="${FFLAGS}"
FC="${FORTRAN}"
FCFLAGS="${FFLAGS}"
OBJC="${OBJC}"
OBJCFLAGS="${OBJCFLAGS}"
MAKE="${MAKE}"
MAKEFLAGS="${MAKEFLAGS}"
MAIN_LD="${MAIN_LD}"
LDFLAGS="${LDFLAGS}"
EOM

make distclean
make clean

echo "Press ENTER when you are ready to continue."
echo "Working directory: $(pwd)"
read -r

CPPFLAGS="${CPPFLAGS}" LDFLAGS="${LDFLAGS}" ./configure            \
    --with-blas="-L${HOMEBREW_PREFIX}/opt/openblas/lib -lopenblas" \
    --with-lapack="-L/${HOMEBREW_PREFIX}/opt/lapack/lib -llapack"  \
    --with-cairo                                                   \
    --with-readline                                                \
    --enable-R-shlib                                               \
    --enable-R-profiling                                           \
    --enable-memory-profiling                                      \
    --enable-strict-barrier                                        \
    --disable-R-framework                                          \
    --without-internal-tzcode                                      \
    --without-recommended-packages                                 \
    --x-libraries=/opt/X11/lib                                     \
    --x-includes=/opt/X11/include                                  \
    --prefix="${PREFIX}"                                           \
    "${CONFIGURE_ARGS[@]}"

STATUS="$?"
if [ "${STATUS}" -ne 0 ]; then
    warn 'Configure failed!'
    exit "${STATUS}"
fi

if [ -n "${CONFIGURE_ONLY}" ]; then
    exit 0
fi

## Export sanitizer runtime options so that recommended-package
## compilation (which runs R during make) doesn't halt on the first
## issue surfaced by ASAN/UBSAN.
if [ -n "${USE_SANITIZERS}" ]; then
    for env_line in "${SAN_RUNTIME_ENV[@]}"; do
        export "${env_line}"
    done
fi

make -j10 |& tee compile.log || {
    warn 'Make failed!'
    exit 1
}

mkdir -p "${PREFIX}"
if [ -d "${PREFIX}" ] && [ -w "${PREFIX}" ]; then
    INSTALL="make install"
else
    INSTALL="sudo make install"
fi

${INSTALL} || {
    warn "Installation failed!"
    exit 1
}

## Set up a version-specific user library path
mkdir -p ~/.R/library/${R_TAG}
ETCDIR=$("${PREFIX}/bin/R" -s -e "writeLines(R.home(\"etc\"))")
echo "R_LIBS_USER='~/.R/library/${R_TAG}'" | sudo tee -a "${ETCDIR}/Renviron.site"

yay 'Installation completed successfully!'
cd ${OWD}

